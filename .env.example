# Local Blog CMS
# Keep the CMS on localhost. Do not expose this process directly to the Internet.
BLOG_CMS_HOST=127.0.0.1
PORT=4173

# Set these before exposing the CMS through a tunnel, reverse proxy, or shared machine.
BLOG_CMS_USER=admin
BLOG_CMS_PASSWORD=change-this-long-random-password

# Cloudflare deployment notes
# Do not commit real Cloudflare API tokens.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=
