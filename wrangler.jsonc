{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "dmmsite",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-24",
  "assets": {
    "directory": "./tools/blog-admin",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dmmsite-db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "triggers": {
    "crons": ["0 3 * * *"]
  },
  "vars": {
    "BLOG_CMS_USER": "admin",
    "DMM_RANKING_LIMIT": "10",
    "DMM_RANKING_URL": "https://www.dmm.co.jp/dc/doujin/-/ranking-all/=/submedia=comic/sort=popular/term=h24/"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
