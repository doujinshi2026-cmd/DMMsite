{
  "name": "dmmsite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "blog:admin": "node scripts/blog-admin.mjs",
    "dmm:import": "node scripts/call-cloudflare-dmm-import.mjs",
    "dmm:import:dry": "node scripts/call-cloudflare-dmm-import.mjs --dry-run",
    "dmm:import:legacy": "node scripts/dmm-ranking-import.mjs",
    "dmm:import:legacy:dry": "node scripts/dmm-ranking-import.mjs --dry-run",
    "dmm:affiliate": "node scripts/backfill-dmm-affiliate-links.mjs",
    "dmm:affiliate:dry": "node scripts/backfill-dmm-affiliate-links.mjs --dry-run",
    "cf:config": "node scripts/verify-cloudflare-config.mjs",
    "cf:check": "node --check src/worker.js",
    "cf:dev": "npx wrangler dev --test-scheduled",
    "cf:deploy": "npm run cf:config && npx wrangler deploy",
    "cf:d1:create": "npx wrangler d1 create dmmsite-db",
    "cf:d1:init:local": "npx wrangler d1 execute dmmsite-db --local --file=database/d1-schema.sql",
    "cf:d1:init:remote": "npm run cf:config && npx wrangler d1 execute dmmsite-db --remote --file=database/d1-schema.sql",
    "cf:d1:optimize:local": "npx wrangler d1 execute dmmsite-db --local --file=database/d1-site-performance.sql",
    "cf:d1:optimize:remote": "npm run cf:config && npx wrangler d1 execute dmmsite-db --remote --file=database/d1-site-performance.sql",
    "cf:d1:seed": "node scripts/export-posts-to-d1-seed.mjs",
    "cf:d1:seed:local": "npm run cf:d1:seed && npx wrangler d1 execute dmmsite-db --local --file=database/d1-seed.sql",
    "cf:d1:seed:remote": "npm run cf:config && npm run cf:d1:seed && npx wrangler d1 execute dmmsite-db --remote --file=database/d1-seed.sql",
    "cf:dmm:import": "node scripts/call-cloudflare-dmm-import.mjs",
    "cf:dmm:import:dry": "node scripts/call-cloudflare-dmm-import.mjs --dry-run",
    "cf:dmm:affiliate": "node scripts/call-cloudflare-dmm-affiliate-backfill.mjs",
    "cf:dmm:affiliate:dry": "node scripts/call-cloudflare-dmm-affiliate-backfill.mjs --dry-run",
    "works:update": "node scripts/call-cloudflare-dmm-import.mjs",
    "works:update:dry": "node scripts/call-cloudflare-dmm-import.mjs --dry-run"
  },
  "devDependencies": {
    "wrangler": "^4.94.0"
  }
}
